---
const { bgUrl, text, gridSpan } = Astro.props;
---

<div
  class={`${bgUrl} ${gridSpan} bg-center bg-cover bg-no-repeat overflow-hidden rounded-[50px]`}
>
  <div class="flex justify-center items-center h-full w-full py-17">
    <p class="font-playfair font-light text-base text-white tracking-wide">
      {text}
    </p>
  </div>
</div>
