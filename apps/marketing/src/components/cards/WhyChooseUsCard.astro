---
const { bgUrl, text, gridSpan } = Astro.props;
---

<div
  class={`${bgUrl} ${gridSpan} bg-center bg-cover bg-no-repeat overflow-hidden rounded-4xl md:rounded-[50px]`}
>
  <div class="flex justify-center items-center h-full w-full py-8.25 md:py-17">
    <p
      class="font-lato md:font-playfair text-center font-light text-xs md:text-base text-white tracking-wide"
    >
      {text}
    </p>
  </div>
</div>
