---
import { Image } from "astro:assets";

const { title, subtitle, details, image, missions, footnote } = Astro.props;
---

<section
  class="py-10 md:py-15 xl:py-20 px-6 md:px-12 xl:px-30 flex group max-xl:gap-y-10 gap-x-20 flex-col-reverse items-center xl:flex-row xl:even:flex-row-reverse"
>
  <div class="xl:hidden">
    <button
      class="shopping-cta-button bg-brand-secondary px-6 py-2 rounded-[6px]"
      ><p class="font-lato text-base tracking-wider text-white">
        Start shopping
      </p>
    </button>
  </div>
  <div class="md:w-5/6 xl:w-1/2 xl:rounded-xl overflow-hidden">
    <Image
      src={image}
      alt={title}
      class={"w-full h-70.5 xl:h-125 object-cover"}
    />
  </div>
  <div class="md:w-5/6 xl:w-1/2 xl:group-odd:mr-8.75">
    <div>
      {
        title && (
          <h3 class="font-playfair font-semibold text-[20px] max-xl:text-center  md:text-2xl xl:text-3xl tracking-wide text-black mb-6">
            {title}
          </h3>
        )
      }
      {
        subtitle && (
          <p class="font-lato font-medium text-base md:text-xl xl:text-[20px] max-xl:text-center max-xl:group-last:text-left xl:text-xl tracking-wide mb-2">
            {subtitle}
          </p>
        )
      }
      {
        details && (
          <p class="font-lato font-normal max-xl:text-center text-sm  md:text-base xl:text-xl text-black whitespace-break-spaces">
            {details}
          </p>
        )
      }
    </div>
    <div class="ml-7 xl:ml-5">
      {
        missions && (
          <ul class="list-disc">
            {missions?.map((mission: string) => (
              <li class="text-base xl:text-xl font-lato ">{mission}</li>
            ))}
          </ul>
        )
      }
    </div>
    {
      footnote && (
        <p class="max-md:ml-2 font-lato font-normal text-sm xl:text-base text-black max-xl:text-center xl:text-gray italic mt-4">
          {footnote}
        </p>
      )
    }
    <div class="mt-6 max-xl:hidden xl:group-last:hidden">
      <button class="shopping-cta-button"
        ><p
          class="font-lato italic text-xl tracking-wider text-brand-secondary"
        >
          Start shopping
        </p>
      </button>
    </div>
  </div>
</section>
