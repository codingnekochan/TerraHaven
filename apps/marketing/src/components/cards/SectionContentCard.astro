---
import { Image } from "astro:assets";

const { title, subtitle, details, image, missions, footnote } = Astro.props;
---

<section
  class="py-10 md:py-15 lg:py-20 px-6 md:px-12 lg:px-30 flex group max-lg:gap-y-10 gap-x-20 flex-col-reverse items-center lg:flex-row lg:even:flex-row-reverse"
>
  <div class="lg:hidden">
    <button
      class="shopping-cta-button bg-brand-secondary px-6 py-2 rounded-[6px]"
      ><p class="font-lato text-base tracking-wider text-white">
        Start shopping
      </p>
    </button>
  </div>
  <div class="md:w-5/6 lg:w-1/2 lg:rounded-xl overflow-hidden">
    <Image
      src={image}
      alt={title}
      class={"w-full h-70.5 lg:h-125 object-cover"}
    />
  </div>
  <div class="md:w-5/6 lg:w-1/2 lg:group-odd:mr-8.75">
    <div>
      {
        title && (
          <h3 class="font-playfair font-semibold text-[20px] max-lg:text-center  md:text-2xl lg:text-3xl tracking-wide text-black mb-6">
            {title}
          </h3>
        )
      }
      {
        subtitle && (
          <p class="font-lato font-medium text-base md:text-lg lg:text-[20px] max-lg:text-center max-lg:group-last:text-left lg:text-xl tracking-wide mb-2">
            {subtitle}
          </p>
        )
      }
      {
        details && (
          <p class="font-lato font-normal max-lg:text-center text-sm  md:text-base lg:text-lg text-black whitespace-break-spaces">
            {details}
          </p>
        )
      }
    </div>
    <div class="ml-7 lg:ml-5">
      {
        missions && (
          <ul class="list-disc">
            {missions?.map((mission: string) => (
              <li class="text-base lg:text-lg font-lato ">{mission}</li>
            ))}
          </ul>
        )
      }
    </div>
    {
      footnote && (
        <p class="max-md:ml-2 font-lato font-normal text-sm lg:text-base text-black max-lg:text-center lg:text-gray italic mt-4">
          {footnote}
        </p>
      )
    }
    <div class="mt-6 max-lg:hidden lg:group-last:hidden">
      <button class="shopping-cta-button"
        ><p
          class="font-lato italic text-xl tracking-wider text-brand-secondary"
        >
          Start shopping
        </p>
      </button>
    </div>
  </div>
</section>
