---
import AppStoreImg from "@/icons/appstore.png";
import PlayStoreImg from "@/icons/playstore.png";
import { Icon } from "astro-icon/components";
import Image from "astro/components/Image.astro";
import { format } from "date-fns";

const date = format(new Date(), "yyyy");
const navLinks = [
  { name: "About us", href: "#about" },
  { name: "Products", href: "#products" },
  { name: "Testimonial", href: "#testimonials" },
  { name: "Email us", href: "mailto:terrahaven@opemails.com" },
];
const socialIcons = ["facebook", "instagram", "x"];
const contactMethods = [
  "Email: TerraHaven@gamil.com",
  "125 Evergreen Lane, Willow Creek, OR 97498, USA",
  "Call: 123 456 789",
];
---

<footer class="bg-brand">
  <div class="lg:hidden pt-10 md:pt-20 px-6 md:px-12 pb-6 md:pb-12">
    <div class="flex justify-between gap-16 align-start">
      <div>
        <h3 class="font-lato text-lg leading-5 font-normal text-white">
          Contact us
        </h3>
        <div class="mt-4">
          {
            contactMethods.map((contact) => (
              <p class="leading-5 text-xs md:text-base font-lato text-white60 italic font-normal mb-1 last:mb-0">
                {contact}
              </p>
            ))
          }
        </div>
      </div>
      <div class="flex flex-col text-right">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="font-lato font-normal underline italic text-sm md:text-base leading-relaxed mb-2 last:mb-0 text-white70"
            >
              {link.name}
            </a>
          ))
        }
      </div>
    </div>
    <div class="mt-20">
      <div>
        <p
          class="leading-5 text-sm md:text-base text-center italic font-lato text-white60 font-normal"
        >
          Join Terra Haven Today
        </p>
        <div class="flex gap-4 justify-center items-center mt-4">
          <Image src={PlayStoreImg} alt="Play Store" width={120} />
          <Image src={AppStoreImg} alt="Apple Store" width={120} />
        </div>
      </div>
      <div class="mt-10">
        <h3
          class="font-lato text-sm md:text-base text-center leading-5 font-normal text-white"
        >
          Follow us on our socials
        </h3>
        <div class="mt-2 flex items-center justify-center gap-4">
          {
            socialIcons.map((icon) => (
              <div class="bg-black10 rounded-full border border-accent20 w-7.5 h-7.75 justify-center items-center flex">
                <Icon name={icon} width={15} height={15} />
              </div>
            ))
          }
        </div>
      </div>
      <p
        class="mt-10 text-center font-lato font-normal text-xs text-white50 italic leading-loose"
      >
        Copyright @ {date} TerraHaven, All rights reserved.
      </p>
    </div>
  </div>
  <div class="max-lg:hidden pt-20 pb-10 pr-30 pl-21.25 flex flex-col">
    <div class="self-end mb-20">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="font-lato font-normal underline italic px-3 py-2 text-base leading-relaxed text-white70 mr-5 last:mr-0"
          >
            {link.name}
          </a>
        ))
      }
    </div>
    <div class="flex justify-between items-start">
      <div class="flex flex-col gap-4">
        <h3
          class="font-luckiest text-[26px] leading-8 tracking-wide text-white"
        >
          TerraHaven
        </h3>
        <p class="leading-5 text-lg font-lato text-white60 font-normal">
          Join Terra Haven Today
        </p>
        <div class="flex gap-5 items-center">
          <Image src={PlayStoreImg} alt="Play Store" width={150} />
          <Image src={AppStoreImg} alt="Apple Store" width={150} />
        </div>
      </div>
      <div>
        <h3 class="font-lato text-lg leading-5 font-normal text-white">
          Contact us
        </h3>
        <div class="mt-4">
          {
            contactMethods.map((contact) => (
              <p class="leading-5 text-sm font-lato text-white60 italic font-normal mb-2 last:mb-0">
                {contact}
              </p>
            ))
          }
        </div>
      </div>
      <div>
        <h3 class="font-lato text-lg leading-5 font-normal text-white">
          Follow us on our socials
        </h3>
        <div class="mt-4 flex items-center justify-center gap-4">
          {
            socialIcons.map((icon) => (
              <div class="bg-black10 rounded-full border border-accent20 w-8.75 h-8.75 justify-center items-center flex">
                <Icon name={icon} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
    <p
      class="mt-30 text-center font-lato font-normal text-sm text-white50 italic leading-loose"
    >
      Copyright @ {date} TerraHaven, All rights reserved.
    </p>
  </div>
</footer>
